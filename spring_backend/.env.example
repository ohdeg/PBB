# 프로필 선택 (미설정 시 기본: dev)
SPRING_PROFILES_ACTIVE=dev

# --- Cloudflare R2 / dev (이 파일을 복사해 .env 로 사용, .env는 git에 올리지 말 것) ---
R2_ENABLED=true
R2_ACCOUNT_ID=
R2_BUCKET=pbb-dev
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
R2_KEY_PREFIX=dev/

