# PBB 운영 환경변수 예시 — 이 파일을 복사해 .env.prod 로 쓰고 실제 값을 채우세요.
#   cp .env.prod.example .env.prod
# .env.prod 는 절대 git 에 커밋하지 마세요 (.gitignore 처리됨).
# 사용: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# ── 프로필 ──────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── MySQL ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change-me-strong-root-pw
DB_NAME=baseball_db
DB_USERNAME=baseball_user
DB_PASSWORD=change-me-strong-db-pw
# DB_URL 은 docker-compose.prod.yml 에서 컨테이너 주소로 자동 주입됩니다.

# ── Redis ──────────────────────────────────────────────
REDIS_PASSWORD=change-me-strong-redis-pw
# REDIS_HOST / REDIS_PORT 는 compose 에서 자동 주입됩니다.

# ── 보안 / 인증 ────────────────────────────────────────
# 64자 이상 랜덤 (예: openssl rand -base64 48)
JWT_SECRET_KEY=change-me-very-long-random-secret-at-least-64-chars

# 프론트 배포 주소 (여러 개면 콤마로 구분, 공백 없이)
CORS_ALLOWED_ORIGINS=https://app.pbb.com

# 크로스도메인 쿠키: 프론트/백엔드 도메인이 다르면 None 필수 (백엔드 HTTPS 전제)
# 같은 상위도메인 서브도메인끼리면 Lax 도 가능. 로컬 dev 기본값은 Strict.
COOKIE_SAME_SITE=None

# ── 메일 (Gmail SMTP) ──────────────────────────────────
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# ── Cloudflare R2 ──────────────────────────────────────
R2_ENABLED=true
R2_ACCOUNT_ID=
R2_BUCKET=pbb-prod
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=
R2_KEY_PREFIX=prod/

# ── Cloudflare Tunnel ──────────────────────────────────
# Zero Trust → Networks → Tunnels 에서 터널 생성 후 발급되는 토큰
CLOUDFLARE_TUNNEL_TOKEN=
